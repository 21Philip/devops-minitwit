vrrp_script check_nginx {
    script "/etc/keepalived/check_nginx.sh"
    interval 2
    weight 2
}

vrrp_instance VI_1 {
    state ${state}
    interface eth1
    virtual_router_id 51
    priority ${priority}
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass ${password}
    }

    virtual_ipaddress {
        ${reserved_ip}
    }

    track_script {
        check_nginx
    }
}